# ── App ────────────────────────────────────────
PORT=3000
APP_BASE_URL=http://localhost:3000

# ── OIDC Client (talking to your own provider) ─
OIDC_ISSUER=http://localhost:4000
OIDC_CLIENT_ID=location-app
OIDC_CLIENT_SECRET=location-app-secret

# ── OIDC Provider ──────────────────────────────
OIDC_PORT=4000

# ── Kafka ──────────────────────────────────────
KAFKA_BROKER=localhost:9092
